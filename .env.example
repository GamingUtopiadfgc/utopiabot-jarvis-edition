# Copy this file to ".env" and fill in your key.
# Get an API key at https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default Claude model
# JARVIS_MODEL=claude-sonnet-4-6

# Optional: Ollama server location (default http://127.0.0.1:11434)
# Local models are auto-detected; no key needed. Install from https://ollama.com
# OLLAMA_HOST=http://127.0.0.1:11434
